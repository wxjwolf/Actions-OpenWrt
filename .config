# Target System (64位标准 x86 架构)
CONFIG_TARGET_x86=y
CONFIG_TARGET_x86_64=y
CONFIG_TARGET_x86_64_DEVICE_generic=y

# 输出格式精准控制 (只保留 squashfs 并开启重度压缩)
# CONFIG_TARGET_ROOTFS_TARGZ is not set
# CONFIG_TARGET_ROOTFS_EXT4FS is not set
CONFIG_TARGET_ROOTFS_SQUASHFS=y
CONFIG_TARGET_IMAGES_GZ=y

# 彻底关闭其他虚拟机格式输出
# CONFIG_VM_IMAGES is not set

# 固件分区大小 (根据需要保持 256 或 512)
CONFIG_TARGET_ROOTFS_PARTSIZE=512

# LuCI 基础与汉化
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# 核心替换：必须用 dnsmasq-full 替代默认的 dnsmasq，否则 SSR Plus 无法分流
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_dnsmasq-full=y

# SSR Plus 及其核心组件
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-i18n-ssr-plus-zh-cn=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_shadowsocks-rust=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_redsocks2=y

# 基础工具
CONFIG_PACKAGE_curl=y
